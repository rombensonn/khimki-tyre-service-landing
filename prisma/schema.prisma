generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ServiceType {
  TYRE
  AUTO_SERVICE
  CAR_WASH
  CONSULTATION
}

enum ContactMethod {
  PHONE
  WHATSAPP
  TELEGRAM
}

model Lead {
  id                 String        @id @default(cuid())
  name               String
  phone              String
  serviceType        ServiceType
  carModel           String?
  problemDescription String?
  preferredDate      String?
  preferredTime      String?
  contactMethod      ContactMethod
  comment            String?
  source             String        @default("website")
  userAgent          String?
  ipHash             String?
  createdAt          DateTime      @default(now())

  @@index([createdAt])
  @@index([serviceType])
}
