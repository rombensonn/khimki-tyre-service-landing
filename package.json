{
  "name": "khimki-tyre-service-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:migrate": "mkdir -p prisma && touch prisma/dev.db && prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:deploy:postgres": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "nodemailer": "^8.0.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.6",
    "prisma": "6.19.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
